---
interface Props {
  href: string;
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  category?: string;
  date?: Date;
}

const {
  href,
  title,
  description,
  image,
  imageAlt = '',
  category,
  date,
} = Astro.props;
---

<a
  href={href}
  class="group block rounded-brand overflow-hidden bg-brand-bg border border-black/5 hover:border-black/20 hover:-translate-y-0.5 transition-all"
>
  {image && (
    <div class="aspect-[16/10] overflow-hidden bg-brand-bg-alt">
      <img
        src={image}
        alt={imageAlt}
        loading="lazy"
        class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
      />
    </div>
  )}
  <div class="p-6">
    {category && (
      <p class="text-xs font-medium uppercase tracking-[0.1em] text-brand-fg-muted mb-3">
        {category}
      </p>
    )}
    <h3 class="text-xl font-semibold mb-2 leading-tight">{title}</h3>
    {description && (
      <p class="text-base text-brand-fg-muted line-clamp-3 mb-4">{description}</p>
    )}
    {date && (
      <p class="text-xs text-brand-fg-muted">
        {date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
      </p>
    )}
  </div>
</a>
